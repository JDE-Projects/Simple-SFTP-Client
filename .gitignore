# Saved sessions (host / user / key paths; never passwords) - keep private
servers.json

# Pinned SSH host keys (trust-on-first-use store)
known_hosts

# PyInstaller build artifacts
build/
dist/
*.spec

# Python
__pycache__/
*.pyc

# Personal local launcher (not for distribution)
Launch_*.bat

# Optional debug logs (written next to the exe when toggled on)
Debug_Log_*.txt

# Theme preference (per-machine: the light/dark choice)
*.pref

# Personal roadmap notes (ideas, not for distribution)
roadmap.md

# Local planning notes (kept private, not shared)
roadmap.md
status.md
needs-fixed.md
